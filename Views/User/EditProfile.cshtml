@using Enterprise_E_Commerce_Management_System.ViewModels.User
@model UpdateUserProfileViewModel

@{
    ViewBag.Title = "Edit User Profile";
    string submitName = "Save";
    var countryList = new SelectList(Model.Countries, "Id", "Name");
    string userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div>
    <form asp-action="EditProfile" asp-controller="User" class="mt-4 app-form" style="max-width: 500px;">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="UserName" class="form-label"></label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CountryId" class="form-label"></label>
            <select asp-for="CountryId"
                    asp-items="countryList"
                    class="form-select">
                <option value="">-- Select Country --</option>
            </select>
            <span asp-validation-for="CountryId" class="text-danger"></span>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="Shopping">
                Back to Home
            </a>

            <input type="submit" value="@submitName" class="btn btn-success" />
        </div>

    </form>

    <div class="mt-4">
        <a asp-action="ChangePassword"
           asp-controller="User"
           asp-route-UserId="@userId"
           class="btn btn-outline-primary">
            Change Password
        </a>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
