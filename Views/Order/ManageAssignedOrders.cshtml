@using Enterprise_E_Commerce_Management_System.ViewModels.Order;
@model OrderManagementPagedListViewModel
@{
    ViewData["Title"] = "Orders Management";
}
<!-- Search / Filters -->
<div class="d-flex justify-content-center my-4 px-3">
    <form asp-action="ManageAssignedOrders"
          method="get"
          class="card p-3 search-box">

        <div class="row g-3 align-items-end">

            <div class="col-md-3">
                <label asp-for="Filter.Search" class="form-label"></label>
                <input asp-for="Filter.Search"
                       class="form-control"
                       placeholder="Search by user name" />
            </div> 

            <div class="col-md-2">
                <label asp-for="Filter.PaymentMethod" class="form-label">Status</label>
                <select asp-for="Filter.PaymentMethod"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="@enPaymentMethod.CashOnDelivery">Cash On Delivery</option> 
                </select>
            </div>

            <div class="col-md-2">
                <label asp-for="Filter.PaymentStatus" class="form-label">Status</label>
                <select asp-for="Filter.PaymentStatus"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="@enPaymentStatus.Pending">Pending</option>
                    <option value="@enPaymentStatus.Paid">Paid</option>
                </select>
            </div>

            <div class="col-md-2">
                <label asp-for="Filter.OrderStatus" class="form-label">Status</label>
                <select asp-for="Filter.OrderStatus"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="@enOrderStatus.Pending">Pending</option>
                    <option value="@enOrderStatus.Cancelled">Cancelled</option>
                    <option value="@enOrderStatus.InDelivery">In Delivery</option>
                    <option value="@enOrderStatus.Paid">Paid</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>

        <!-- Page (hidden – pagination controls it) -->
        <input type="hidden" asp-for="Filter.Page" />
    </form>
</div>
<div class="table-wrapper wide-table-wrapper">

    <table class="table app-table">

        <thead>
            <tr>
                <th>Order #</th>
                <th>City</th>
                <th>Amount</th>
                <th>Date</th>
                <th>Courier</th>
                <th>Shipment</th>
                <th>Order</th>
                <th>Payment</th>
                <th>Method</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Orders != null && Model.Orders.Any())
            {
                foreach (var order in Model.Orders)
                {
                    <tr>
                        <td class="fw-semibold">@order.OrderNumber</td>

                        <td>@order.City</td>

                        <td>@order.Amount.ToString("N2") @Model.CurrencyCode</td>

                        <td>@order.OrderDate</td>

                        <td>
                            @(string.IsNullOrEmpty(order.CourierUserName)
                                                ? "-"
                                                : order.CourierUserName)
                </td>

                        <td>
                            <span class="badge bg-secondary">
                                @order.ShipmentStatus
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-primary">
                                @order.OrderStatus
                            </span>
                        </td>

                        <td>
                            <span class="badge @(order.PaymentStatus == null ? "bg-secondary" : "bg-success")">
                                @(order.PaymentStatus?.ToString() ?? "N/A")
                            </span>
                        </td>

                        <td>
                            @(order.PaymentMethod?.ToString() ?? "-")
                        </td>

                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Details"
                                   asp-controller="Order"
                                   asp-route-OrderId="@order.OrderId"
                                   class="btn btn-sm btn-outline-primary">
                                    View Order
                                </a>

                        @if (order.CourierId > 0)
                                {
                                    <a asp-action="Details"
                                       asp-controller="Courier"
                                       asp-route-CourierId="@order.CourierId"
                                       class="btn btn-sm btn-outline-secondary">
                                        View Courier
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">
                        No orders found
                    </td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="10">
                    Total Orders:
                    <strong>@Model.Count</strong>
                </td>
            </tr>
        </tfoot>

    </table>

</div>
<!-- Pagination -->
@if (Model.Count > Model.Filter.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Count / (double)Model.Filter.PageSize);
    var currentPage = Model.Filter.Page;

    <div class="pagination-wrapper mt-4 d-flex justify-content-center">
        <nav class="pagination ">
            <ul role="list">

                <!-- Prev -->
                <li>
                    <a class="pg-btn @(currentPage == 1 ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage > 1 ? currentPage - 1 : 1)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.PaymentStatus="@Model.Filter.PaymentStatus"
                       asp-route-Filter.PaymentMethod="@Model.Filter.PaymentMethod"
                       asp-route-Filter.OrderStatus="@Model.Filter.OrderStatus">
                        Prev
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="pg-btn @(i == currentPage ? "is-active" : "")"
                           asp-action="Index"
                           asp-route-Filter.Page="@i"
                           asp-route-Filter.Search="@Model.Filter.Search"
                           asp-route-Filter.PaymentStatus="@Model.Filter.PaymentStatus"
                           asp-route-Filter.PaymentMethod="@Model.Filter.PaymentMethod"
                           asp-route-Filter.OrderStatus="@Model.Filter.OrderStatus">
                            @i
                        </a>
                    </li>
                }

                <!-- Next -->
                <li>
                    <a class="pg-btn @(currentPage == totalPages ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.PaymentStatus="@Model.Filter.PaymentStatus"
                       asp-route-Filter.PaymentMethod="@Model.Filter.PaymentMethod"
                       asp-route-Filter.OrderStatus="@Model.Filter.OrderStatus">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    </div>
}