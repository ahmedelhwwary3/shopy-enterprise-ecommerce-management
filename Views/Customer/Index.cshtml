@using Enterprise_E_Commerce_Management_System.ViewModels.Customer
@using Enterprise_E_Commerce_Management_System.Models.Customers
@model CustomerPagedListViewModel

@{
    ViewData["Title"] = "Manage Customers";
    var countryList = new SelectList(Model.Countries, "Id", "Name");
}

<partial name="_Notifications"> 

<a asp-action="Form" class="btn btn-primary mb-3">
    Create New Customer
</a>

<!-- Search / Filters -->
<div class="d-flex justify-content-center my-4 px-3">
    <form asp-action="Index"
          method="get"
          class="card p-3 search-box">

        <div class="row g-3 align-items-end">

            <div class="col-md-3">
                <label asp-for="Filter.Search" class="form-label"></label>
                <input asp-for="Filter.Search"
                       class="form-control"
                       placeholder="Name, email, phone" />
            </div>

            <div class="col-md-3">
                <label asp-for="Filter.CountryId" class="form-label">Country</label>
                <select asp-for="Filter.CountryId"
                        asp-items="@countryList"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                </select>
            </div>

            <div class="col-md-2">
                <label asp-for="Filter.IsActive" class="form-label">Status</label>
                <select asp-for="Filter.IsActive"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>

        <!-- Page (hidden – pagination only) -->
        <input type="hidden" asp-for="Filter.Page" />
    </form>
</div>

<div class="table-wrapper">
    <!-- Table -->
    <table class="table table-bordered">
        <thead>
            <tr>
                <!-- ترتيب مريح -->
                <th>Full Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Country</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Customers != null && Model.Customers.Any())
            {
                foreach (var customer in Model.Customers)
                {
                    var changeStatus = customer.Status == "Active" ? "Deactivate" : "Activate";

                    <tr>
                        <td>@customer.FullName</td>
                        <td>@customer.PhoneNumber</td>
                        <td>@customer.Email</td>
                        <td>@customer.Country</td>
                        <td>@customer.Status</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Form"
                                   asp-route-Id="@customer.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <form asp-action="ChangeStatus"
                                      method="post"
                                      onsubmit="return confirm('Are you sure you want to @changeStatus this customer?')">
                                    <input type="hidden" name="Id" value="@customer.Id" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-secondary">
                                        @changeStatus
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">No customers found</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="6">
                    Total Count: <strong>@Model.Count</strong>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

<!-- Pagination -->
@if (Model.Count > Model.Filter.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Count / (double)Model.Filter.PageSize);
    var currentPage = Model.Filter.Page;

    <div class="pagination-wrapper mt-4 d-flex justify-content-center">
        <nav class="pagination  ">
            <ul role="list">

                <!-- Prev -->
                <li>
                    <a class="pg-btn @(currentPage == 1 ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage > 1 ? currentPage - 1 : 1)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.CountryId="@Model.Filter.CountryId"
                       asp-route-Filter.IsActive="@Model.Filter.IsActive">
                        Prev
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="pg-btn @(i == currentPage ? "is-active" : "")"
                           asp-action="Index"
                           asp-route-Filter.Page="@i"
                           asp-route-Filter.Search="@Model.Filter.Search"
                           asp-route-Filter.CountryId="@Model.Filter.CountryId"
                           asp-route-Filter.IsActive="@Model.Filter.IsActive">
                            @i
                        </a>
                    </li>
                }

                <!-- Next -->
                <li>
                    <a class="pg-btn @(currentPage == totalPages ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.CountryId="@Model.Filter.CountryId"
                       asp-route-Filter.IsActive="@Model.Filter.IsActive">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    </div>
}
