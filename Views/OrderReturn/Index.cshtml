@using Enterprise_E_Commerce_Management_System.Models.OrderReturns
@using Enterprise_E_Commerce_Management_System.ViewModels.OrderReturn
@model OrderReturnPagedListViewModel

@{
    ViewBag.Title = "Order Returns";
    var countryList = new SelectList(Model.Filter.Countries, "Id", "Name");
}

<partial name="_Notifications"></partial>

<!-- Search / Filters -->
<div class="d-flex justify-content-center my-4 px-3">
    <form asp-action="Index"
          method="get"
          class="card p-3 search-box">

        <div class="row g-3 align-items-end">

            <div class="col-md-3">
                <label asp-for="Filter.Search" class="form-label"></label>
                <input asp-for="Filter.Search"
                       class="form-control"
                       placeholder="Order number, email, phone" />
            </div>

            <div class="col-md-3">
                <label asp-for="Filter.CountryId" class="form-label">Country</label>
                <select asp-for="Filter.CountryId"
                        asp-items="@countryList"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                </select>
            </div>

            <div class="col-md-3">
                <label asp-for="Filter.ReturnStatus" class="form-label">Return Status</label>
                <select asp-for="Filter.ReturnStatus"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="@enOrderReturnStatus.Requested">Requested</option>
                    <option value="@enOrderReturnStatus.Returned">Returned</option>
                    <option value="@enOrderReturnStatus.Rejected">Rejected</option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>

        <!-- Page (hidden – pagination only) -->
        <input type="hidden" asp-for="Filter.Page" />
    </form>
</div>
<div class="table-wrapper wide-table-wrapper">
    <!-- Table -->
    <table class="table table-bordered">
        <thead>
            <tr>
                <!-- ترتيب مريح -->
                <th>Order Number</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Country</th>
                <th>Courier</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Requested At</th>
                <th>Picked Up At</th>
                <th>Returned At</th>
                <th>Payment Date</th>
                <th>Notes</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.OrderReturns != null && Model.OrderReturns.Any())
            {
                foreach (var r in Model.OrderReturns)
                {
                    <tr>
                        <td>@r.OrderNumber</td>
                        <td>@r.Email</td>
                        <td>@r.PhoneNumber</td>
                        <td>@r.CountryName</td>
                        <td>@r.CourierUserName</td>
                        <td>@r.Amount.ToString("N2") @Model.CurrencyCode</td>
                        <td>@r.ReturnStatus</td>
                        <td>@r.RequestedAt</td>
                        <td>@r.PickedUpAt</td>
                        <td>@r.ReturnedAt</td>
                        <td>@r.PaymentDate</td>
                        <td>@r.Notes</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="12">No order returns found</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="12">
                    Total Count: <strong>@Model.Count</strong>
                </td>
            </tr>
        </tfoot>
    </table>
</div>


<!-- Pagination -->
@if (Model.Count > Model.Filter.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Count / (double)Model.Filter.PageSize);
    var currentPage = Model.Filter.Page;

    <div class="pagination-wrapper mt-4 d-flex justify-content-center">
        <nav class="pagination  ">
            <ul role="list">

                <!-- Prev -->
                <li>
                    <a class="pg-btn @(currentPage == 1 ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.CountryId="@Model.Filter.CountryId"
                       asp-route-Filter.ReturnStatus="@Model.Filter.ReturnStatus">
                        Prev
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="pg-btn @(i == currentPage ? "is-active" : "")"
                           asp-action="Index"
                           asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                           asp-route-Filter.Search="@Model.Filter.Search"
                           asp-route-Filter.Search="@Model.Filter.Search"
                           asp-route-Filter.CountryId="@Model.Filter.CountryId"
                           asp-route-Filter.ReturnStatus="@Model.Filter.ReturnStatus">
                            @i
                        </a>
                    </li>
                }

                <!-- Next -->
                <li>
                    <a class="pg-btn @(currentPage == totalPages ? "disabled" : "")" 
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.CountryId="@Model.Filter.CountryId"
                       asp-route-Filter.ReturnStatus="@Model.Filter.ReturnStatus">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    </div>
}  