@using Enterprise_E_Commerce_Management_System.ViewModels.ShippingProvider
@model ShippingProviderPagedListViewModel

@{
    ViewData["Title"] = "Manage Shipping Providers";
}

<partial name="_Notifications"> 
<!-- Search / Filters -->
<div class="d-flex justify-content-center my-4 px-3">
    <form asp-action="Index" method="get" class="card p-3 search-box">
        <div class="row g-3 align-items-end">

            <!-- Search -->
            <div class="col-md-4">
                <label asp-for="Filter.Search" class="form-label"></label>
                <input asp-for="Filter.Search" class="form-control" placeholder="Search by name" />
            </div>

            <!-- Status -->
            <div class="col-md-3">
                <label asp-for="Filter.IsActive" class="form-label">Status</label>
                <select asp-for="Filter.IsActive"
                        class="form-select"
                        onchange="this.form.submit()">
                    <option value="">All</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>

            <!-- Submit -->
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>

        <!-- Page (hidden, pagination only controls it) -->
        <input type="hidden" asp-for="Filter.Page" />
    </form>
</div>
<a asp-action="Form" asp-controller="ShippingProvider" class="btn btn-primary mb-3">
    Create Shipping Provider
</a>

<div class="table-wrapper">
    <!-- Table -->
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Couriers Count</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Providers != null && Model.Providers.Any())
            {
                foreach (var provider in Model.Providers)
                {
                    <tr>
                        <td>@provider.Name</td>
                        <td>@provider.CouriersCount</td>
                        <td>
                            <a asp-action="Form"
                               asp-controller="ShippingProvider"
                               asp-route-ShippingProviderId="@provider.Id"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3">No Shipping Providers found</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="3">
                    Total Count: <strong>@Model.Count</strong>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

 
<!-- Pagination -->
@if (Model.Count > Model.Filter.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Count / (double)Model.Filter.PageSize);
    var currentPage = Model.Filter.Page;

    <div class="pagination-wrapper mt-4 d-flex justify-content-center">
        <nav class="pagination ">
            <ul role="list">

                <!-- Prev -->
                <li>
                    <a class="pg-btn @(currentPage == 1 ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.IsActive="@Model.Filter.IsActive">
                        Prev
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="pg-btn @(i == currentPage ? "is-active" : "")"
                           asp-action="Index"
                           asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                           asp-route-Filter.Search="@Model.Filter.Search"
                           asp-route-Filter.IsActive="@Model.Filter.IsActive">
                            @i
                        </a>
                    </li>
                }

                <!-- Next -->
                <li>
                    <a class="pg-btn @(currentPage == totalPages ? "disabled" : "")"
                       asp-action="Index"
                       asp-route-Filter.Page="@(currentPage<totalPages? currentPage + 1 : totalPages)"
                       asp-route-Filter.Search="@Model.Filter.Search"
                       asp-route-Filter.IsActive="@Model.Filter.IsActive">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    </div>
} 