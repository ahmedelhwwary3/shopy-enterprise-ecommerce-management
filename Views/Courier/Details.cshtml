@using Enterprise_E_Commerce_Management_System.ViewModels.Courier
@model CourierDetailsViewModel
@{
    ViewBag.Title = "Courier Details";
}

<div class="app-wrapper">

    <div class="card shadow-sm">

        <div class="card-header bg-light">
            <h5 class="mb-0">Courier Details</h5>
        </div>

        <div class="card-body">
            <div class="row g-3">

                <div class="col-md-6">
                    <div class="detail-item">
                        <div class="detail-label">Country</div>
                        <div class="detail-value">@Model.Country</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="detail-item">
                        <div class="detail-label">Phone Number</div>
                        <div class="detail-value">@Model.PhoneNumber</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="detail-item">
                        <div class="detail-label">Email</div>
                        <div class="detail-value">@Model.Email</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="detail-item">
                        <div class="detail-label">Username</div>
                        <div class="detail-value">@Model.UserName</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="detail-item">
                        <div class="detail-label">Shipping Provider</div>
                        <div class="detail-value">@Model.ShippingProvider</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="detail-item">
                        <div class="detail-label">Status</div>
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <!-- ================= Actions ================= -->
        <div class="card-footer">
            <div class="form-actions">
                <a class="btn btn-back"
                   asp-action="ManageAssignedOrders"
                   asp-controller="Order">
                    Back to List
                </a>

                <a asp-route-CourierId="@Model.Id"
                   asp-action="Edit"
                   class="btn btn-sm btn-outline-primary">
                    Edit
                </a>
            </div>
        </div>

    </div>

</div>
