@using Enterprise_E_Commerce_Management_System.ViewModels.UserProducts;
@model ProductFormViewModel

@{
    ViewBag.Title = "Edit Product";
}
<div class="app-wrapper">

    <!-- ================= Product Form ================= -->
    <div class="card shadow-sm mb-4">
        <partial name="_ProductForm">
    </div>
    <!-- ================= Product Actions ================= -->
    <form id="deleteProductForm-@Model.Id"
          asp-action="Delete"
          method="post"
          onsubmit="return confirm('Are you sure you want to delete this product?')"
          class="d-none">
        <input type="hidden" name="Id" value="@Model.Id" />
    </form>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-end gap-2 flex-wrap">

                <button type="button"
                        class="btn btn-outline-danger"
                        onclick="document.getElementById('deleteProductForm-@Model.Id').submit();">
                    Delete
                </button>

                <a asp-action="Form"
                   asp-controller="Variant"
                   asp-route-productId="@Model.Id"
                   class="btn btn-outline-primary">
                    Create New Variant
                </a>

            </div>
        </div>
    </div>

    <!-- ================= Variants Section ================= -->
    <div class="card shadow-sm">

        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Product Variants</span>

            <button type="button"
                    id="btnLoad"
                    class="btn btn-sm btn-outline-secondary">
                Show Variants
            </button>
        </div>

        <div class="card-body">

            <!-- ================= Search ================= -->
            <form id="searchContainer">

                <input type="hidden" id="ProductId" value="@Model.Id" />

                <div class="row g-3 align-items-end">

                    <div class="col-md-4">
                        <label class="form-label">SKU</label>
                        <input type="text"
                               id="SKU"
                               class="form-control"
                               placeholder="Search by SKU" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Status</label>
                        <select id="IsActive" class="form-select">
                            <option value="">All</option>
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button type="button"
                                id="btnSearch"
                                class="btn btn-success w-100">
                            Search
                        </button>
                    </div>

                </div>
            </form>

            <!-- ================= Results ================= -->
            <div id="variantsContainer" class="mt-4"></div>

            <div id="paginationContainer"
                 class="d-flex justify-content-center mt-3">
            </div>

        </div>
    </div>

</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            /* ================= State ================= */
            let currentPage = 1;

            const searchContainer = document.getElementById("searchContainer");
            const btnLoad = document.getElementById("btnLoad");
            const btnSearch = document.getElementById("btnSearch");
            const statusSelect = document.getElementById("IsActive");

            if (searchContainer) {
                searchContainer.style.display = "none";
            }

            /* ================= Show Variants ================= */
            btnLoad.addEventListener("click", function () {
                currentPage = 1;
                loadVariants();
                searchContainer.style.display = "block";
                btnLoad.style.display = "none";
            });

            /* ================= Search Button ================= */
            btnSearch.addEventListener("click", function (e) {
                e.preventDefault();
                currentPage = 1;
                loadVariants();
            });

            /* ================= Status Auto Reload ================= */
            statusSelect.addEventListener("change", function () {
                currentPage = 1;
                loadVariants();
            });

            /* ================= Pagination Change ================= */
            window.changePage = function (page) {
                currentPage = page;
                loadVariants();
            };

            /* ================= Load Variants ================= */
            function loadVariants() {

                const productId = document.getElementById("ProductId").value;
                const sku = document.getElementById("SKU").value || "";
                const status = statusSelect.value || "";

                const params = new URLSearchParams();

                params.append("ProductId", productId);
                params.append("Page", currentPage); // ✅ state-based

                if (sku) params.append("SKU", sku);
                if (status !== "") params.append("IsActive", status);

                fetch(`/Variant/Search?${params.toString()}`)
                    .then(res => res.text())
                    .then(html => {
                        document.getElementById("variantsContainer").innerHTML = html;
                        scrollToVariants();
                    })
                    .catch(err => console.error(err));
            }

            /* ================= Scroll ================= */
            function scrollToVariants() {

                const container = document.getElementById("variantsContainer");
                if (!container) return;

                const offset = 100;
                const top =
                    container.getBoundingClientRect().top +
                    window.pageYOffset -
                    offset;

                window.scrollTo({
                    top: top,
                    behavior: "smooth"
                });
            }

        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}


