@using Enterprise_E_Commerce_Management_System.ViewModels.Cart
@model CartDetailsViewModel

@{
    ViewBag.Title = "Cart Details";
}

<div class="app-wrapper">

    <div class="card shadow-sm">

        <div class="card-header bg-light">
            <h5 class="mb-0">Your Cart</h5>
        </div>

        <div class="card-body">

            <!-- ================= Cart Items ================= -->
            <div class="row g-4">

                @foreach (var item in Model.Items)
                {
                    <div class="col-12 col-md-6 col-lg-4">

                        <div class="card h-100 shadow-sm">

                            <div class="card-body d-flex flex-column">

                                <div class="text-center mb-3">
                                    <img src="~/Images/@item.ImageName"
                                         alt="@item.ProductName"
                                         class="img-fluid rounded"
                                         style="max-height:150px;" />
                                </div>

                                <h6 class="fw-bold">@item.ProductName</h6>

                                <div class="mb-2 small text-muted">

                                    @foreach (var attr in item.Attributes)
                                    {
                                        <div>
                                            <strong>@attr.Name:</strong> @attr.Value
                                        </div>
                                    }

                                    <div>
                                        <strong>Qty:</strong> @item.Quantity
                                    </div>

                                </div>

                                <div class="mt-auto">

                                    <div class="d-flex justify-content-between">
                                        <span>Unit:</span>
                                        <span>@item.UnitPrice.ToString("N2") @Model.Code</span>
                                    </div>

                                    <div class="d-flex justify-content-between fw-bold">
                                        <span>Total:</span>
                                        <span>@item.TotalPrice.ToString("N2") @Model.Code</span>
                                    </div>

                                    <div class="mt-3 text-end">
                                        <form asp-action="RemoveItem"
                                              method="post"
                                              class="d-inline">
                                            <input type="hidden"
                                                   name="ItemId"
                                                   value="@item.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger">
                                                Remove
                                            </button>
                                        </form>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>

            <!-- ================= Summary ================= -->
            <div class="cart-summary">
                <div>
                    <span>Total Items</span>
                    <strong>@Model.TotalCount</strong>
                </div>
                <div>
                    <span>Total Price</span>
                    <strong>@Model.TotalPrice.ToString("N2") @Model.Code</strong>
                </div>
            </div>

        </div>

        <!-- ================= Actions ================= -->
        <div class="card-footer">
            <div class="form-actions d-flex gap-2 justify-content-end">

                <a class="btn btn-back"
                   asp-action="Index"
                   asp-controller="Shopping">
                    Back to Shopping
                </a>

                <!-- Clear Cart -->
                <form asp-action="DeleteCart"
                      method="post"
                      class="d-inline ms-2">
                    <input type="hidden"
                           name="CartId"
                           value="@Model.Id" />
                    <button type="submit"
                            class="btn btn-outline-danger">
                        Clear Cart
                    </button>
                </form>

                <a asp-controller="Order"
                   asp-action="CheckOut"
                   class="btn btn-success">
                    Check Out
                </a>

            </div>
        </div>

    </div>

</div>
