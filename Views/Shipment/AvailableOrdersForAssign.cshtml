@using Enterprise_E_Commerce_Management_System.ViewModels.Order
@using Enterprise_E_Commerce_Management_System.ViewModels.Shipment

@model AvailableOrderPagedListViewModel

@{
    ViewData["Title"] = "Order Shipment";
}

<partial name="_Notifications"> 

<!-- Search -->
<div class="d-flex justify-content-center my-4 px-3">
    <form asp-action="AvailableOrdersForAssign"
          method="get"
          class="card p-3 search-box">

        <div class="row g-3 align-items-end">

            <div class="col-md-4">
                <label asp-for="Filter.Search" class="form-label"></label>
                <input asp-for="Filter.Search"
                       class="form-control"
                       placeholder="Order number, city" />
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>

        <!-- Page (hidden – pagination only) -->
        <input type="hidden" asp-for="Filter.Page" />
    </form>
</div>

<!-- Table -->
<div class="table-wrapper">
    <table class="table table-bordered">
        <thead>
            <tr>
                <!-- ترتيب مريح -->
                <th>Order Number</th>
                <th>City</th>
                <th>Amount</th>
                <th>Order Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Orders != null && Model.Orders.Any())
            {
                foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.City</td>
                        <td>@order.Amount.ToString("N2") @Model.CurrencyCode</td>
                        <td>@order.OrderDate</td>
                        <td>@order.Status</td>
                        <td>
                            <a asp-action="Details"
                               asp-route-OrderId="@order.Id"
                               class="btn btn-sm btn-outline-primary">
                                Take Order
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">No orders available</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="6">
                    Total Count: <strong>@Model.Count</strong>
                </td>
            </tr>
        </tfoot>
    </table>
</div>


<!-- Pagination (Full Request) -->
@if (Model.Count > Model.Filter.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Count / (double)Model.Filter.PageSize);

    <div class="pagination-wrapper mt-4 d-flex justify-content-center">
        <nav class="pagination " aria-label="Orders Pagination">
            <ul role="list">

                <!-- Prev -->
                <li>
                    <a class="pg-btn @(Model.Filter.Page <= 1 ? "disabled" : "")"
                       asp-action="PendingOrders"
                       asp-route-Filter.Page="@(Model.Filter.Page - 1)"
                       asp-route-Filter.Search="@Model.Filter.Search">
                        Prev
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="pg-btn @(i == Model.Filter.Page ? "is-active" : "")"
                           asp-action="PendingOrders"
                           asp-route-Filter.Page="@i"
                           asp-route-Filter.Search="@Model.Filter.Search" >
                            @i
                        </a>
                    </li>
                }

                <!-- Next -->
                <li>
                    <a class="pg-btn @(Model.Filter.Page >= totalPages ? "disabled" : "")"
                       asp-action="PendingOrders"
                       asp-route-Filter.Page="@(Model.Filter.Page + 1)"
                       asp-route-Filter.Search="@Model.Filter.Search" >
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    </div>
}
